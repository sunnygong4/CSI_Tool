# Docker build-time dependency
# Point this at a Linux dnglab release asset URL before building.
DNGLAB_DOWNLOAD_URL=https://github.com/dnglab/dnglab/releases/download/<tag>/<linux-asset>

# Web app identity
CSI_WEB_ENV=production
CSI_WEB_APP_NAME=CSI Tool Web
CSI_WEB_PUBLIC_BASE_URL=https://csi.sunnygong.com
CSI_WEB_APP_SECRET=replace-with-a-long-random-secret
CSI_WEB_CLIENT_IP_SALT=replace-with-a-second-random-secret

# Runtime paths inside the container
CSI_WEB_DATABASE_PATH=/app/data/csi_web.db
CSI_WEB_WORK_ROOT=/app/data/work
CSI_WEB_LOCAL_STORAGE_ROOT=/app/data/storage
CSI_WEB_LOG_PATH=/app/data/csi_web.log
CSI_WEB_STORAGE_BACKEND=r2
CSI_WEB_HOST_PORT=6030

# Extraction defaults
CSI_WEB_DNGLAB_PATH=/usr/local/bin/dnglab
CSI_WEB_REQUIRE_DNGLAB=true
CSI_WEB_DEFAULT_OUTPUT_FORMAT=dng
CSI_WEB_UPLOAD_MAX_BYTES=2147483648
CSI_WEB_PER_IP_ACTIVE_LIMIT=1
CSI_WEB_PER_IP_HOURLY_LIMIT=3
CSI_WEB_PROCESSING_CONCURRENCY=1
CSI_WEB_JOB_TTL_SECONDS=3600
CSI_WEB_POST_DOWNLOAD_TTL_SECONDS=300
CSI_WEB_CLEANUP_INTERVAL_SECONDS=600
CSI_WEB_WORKER_POLL_SECONDS=5
CSI_WEB_PRESIGNED_UPLOAD_EXPIRATION_SECONDS=900
CSI_WEB_PRESIGNED_DOWNLOAD_EXPIRATION_SECONDS=900
CSI_WEB_LOG_TAIL_LINES=400
CSI_WEB_ADMIN_TOKEN=replace-with-a-separate-admin-token
CSI_WEB_ADMIN_SESSION_HOURS=12

# Cloudflare R2
CSI_WEB_R2_ENDPOINT_URL=https://<account-id>.r2.cloudflarestorage.com
CSI_WEB_R2_REGION_NAME=auto
CSI_WEB_R2_ACCESS_KEY_ID=your-r2-access-key-id
CSI_WEB_R2_SECRET_ACCESS_KEY=your-r2-secret-access-key
CSI_WEB_R2_BUCKET_NAME=your-r2-bucket
CSI_WEB_R2_UPLOAD_PREFIX=uploads
CSI_WEB_R2_RESULT_PREFIX=results
